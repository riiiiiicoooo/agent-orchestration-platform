# ============================================================================
# Agent Orchestration Platform — Environment Variables
# ============================================================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_orchestration

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Auth (Clerk)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Observability (LangSmith)
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agent-orchestration
LANGCHAIN_TRACING_V2=true

# Optional
DATADOG_API_KEY=
SENTRY_DSN=
